SELECT [s].[Id], [s].[AcademicProgramId], [s].[AcademicSessionId], [s].[AccountCreatedAt], [s].[ApplicationNumber], [s].[CreatedAt], [s].[EmergencyContactJson], [s].[EntraObjectId], [s].[FacultyId], [s].[FirstName], [s].[JambRegNumber], [s].[LastName], [s].[MiddleName], [s].[OfferExpiresAt], [s].[OfficialEmail], [s].[Persona], [s].[Phone], [s].[ProgramReason], [s].[QualificationsJson], [s].[SponsorshipJson], [s].[Status], [s].[StudentEmail], [s].[StudentId], [s].[SubmittedAt], [s].[UpdatedAt], [s].[Id0], [s].[EndDate], [s].[IsActive], [s].[IsAdmissionOpen], [s].[Name], [s].[StartDate], [s].[Id1], [s].[CreatedDate], [s].[Label], [s].[Name0], [s].[UpdatedDate], [s].[Id2], [s].[Code], [s].[DegreeAwarded], [s].[DepartmentId], [s].[Description], [s].[DurationYears], [s].[FacultyId0], [s].[IsActive0], [s].[MaxAdmissions], [s].[MinJambScore], [s].[Name1], [s].[RequiredJambSubjectsJson], [s].[RequiredOLevelSubjectsJson], [s].[Type], [s0].[AdmissionApplicationId], [s0].[DocumentsId], [s0].[Id], [s0].[AccessMetadata], [s0].[DocumentTypeId], [s0].[FacultyId], [s0].[FileName], [s0].[FileSize], [s0].[FileType], [s0].[FileUrl], [s0].[OwnerId], [s0].[RejectionReason], [s0].[Status], [s0].[UploadedAt], [s0].[Id0], [s0].[Category], [s0].[Code], [s0].[DefaultAccessRules], [s0].[Description], [s0].[IsActive], [s0].[IsCompulsory], [s0].[Name]
FROM (
    SELECT TOP(1) [a].[Id], [a].[AcademicProgramId], [a].[AcademicSessionId], [a].[AccountCreatedAt], [a].[ApplicationNumber], [a].[CreatedAt], [a].[EmergencyContactJson], [a].[EntraObjectId], [a].[FacultyId], [a].[FirstName], [a].[JambRegNumber], [a].[LastName], [a].[MiddleName], [a].[OfferExpiresAt], [a].[OfficialEmail], [a].[Persona], [a].[Phone], [a].[ProgramReason], [a].[QualificationsJson], [a].[SponsorshipJson], [a].[Status], [a].[StudentEmail], [a].[StudentId], [a].[SubmittedAt], [a].[UpdatedAt], [a0].[Id] AS [Id0], [a0].[EndDate], [a0].[IsActive], [a0].[IsAdmissionOpen], [a0].[Name], [a0].[StartDate], [f].[Id] AS [Id1], [f].[CreatedDate], [f].[Label], [f].[Name] AS [Name0], [f].[UpdatedDate], [p].[Id] AS [Id2], [p].[Code], [p].[DegreeAwarded], [p].[DepartmentId], [p].[Description], [p].[DurationYears], [p].[FacultyId] AS [FacultyId0], [p].[IsActive] AS [IsActive0], [p].[MaxAdmissions], [p].[MinJambScore], [p].[Name] AS [Name1], [p].[RequiredJambSubjectsJson], [p].[RequiredOLevelSubjectsJson], [p].[Type]
    FROM [AdmissionApplications] AS [a]
    INNER JOIN [AcademicSessions] AS [a0] ON [a].[AcademicSessionId] = [a0].[Id]
    LEFT JOIN [Faculties] AS [f] ON [a].[FacultyId] = [f].[Id]
    LEFT JOIN [Programs] AS [p] ON [a].[AcademicProgramId] = [p].[Id]
    WHERE [a].[StudentEmail] = @email OR [a].[JambRegNumber] = @jambRegNumber
    ORDER BY [a].[CreatedAt] DESC
) AS [s]
LEFT JOIN (
    SELECT [a1].[AdmissionApplicationId], [a1].[DocumentsId], [d].[Id], [d].[AccessMetadata], [d].[DocumentTypeId], [d].[FacultyId], [d].[FileName], [d].[FileSize], [d].[FileType], [d].[FileUrl], [d].[OwnerId], [d].[RejectionReason], [d].[Status], [d].[UploadedAt], [d0].[Id] AS [Id0], [d0].[Category], [d0].[Code], [d0].[DefaultAccessRules], [d0].[Description], [d0].[IsActive], [d0].[IsCompulsory], [d0].[Name]
    FROM [AdmissionApplicationDocuments] AS [a1]
    INNER JOIN [DocumentRecords] AS [d] ON [a1].[DocumentsId] = [d].[Id]
    INNER JOIN [DocumentTypes] AS [d0] ON [d].[DocumentTypeId] = [d0].[Id]
) AS [s0] ON [s].[Id] = [s0].[AdmissionApplicationId]
ORDER BY [s].[CreatedAt] DESC, [s].[Id], [s].[Id0], [s].[Id1], [s].[Id2], [s0].[AdmissionApplicationId], [s0].[DocumentsId], [s0].[Id]
