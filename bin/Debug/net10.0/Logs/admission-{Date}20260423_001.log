FROM (
    SELECT TOP(1) [a].[Id], [a].[AcademicProgramId], [a].[AcademicSessionId], [a].[ApplicationNumber], [a].[CreatedAt], [a].[EmergencyContactJson], [a].[FacultyId], [a].[JambRegNumber], [a].[Persona], [a].[Phone], [a].[ProgramReason], [a].[QualificationsJson], [a].[SponsorshipJson], [a].[Status], [a].[StudentEmail], [a].[StudentName], [a].[SubmittedAt], [a].[UpdatedAt], [a0].[Id] AS [Id0], [a0].[EndDate], [a0].[IsActive], [a0].[IsAdmissionOpen], [a0].[Name], [a0].[StartDate], [f].[Id] AS [Id1], [f].[CreatedDate], [f].[Label], [f].[Name] AS [Name0], [f].[UpdatedDate], [p].[Id] AS [Id2], [p].[Code], [p].[DegreeAwarded], [p].[DepartmentId], [p].[Description], [p].[DurationYears], [p].[FacultyId] AS [FacultyId0], [p].[IsActive] AS [IsActive0], [p].[MaxAdmissions], [p].[MinJambScore], [p].[Name] AS [Name1], [p].[RequiredJambSubjectsJson], [p].[RequiredOLevelSubjectsJson], [p].[Type]
    FROM [AdmissionApplications] AS [a]
    INNER JOIN [AcademicSessions] AS [a0] ON [a].[AcademicSessionId] = [a0].[Id]
    LEFT JOIN [Faculties] AS [f] ON [a].[FacultyId] = [f].[Id]
    LEFT JOIN [Programs] AS [p] ON [a].[AcademicProgramId] = [p].[Id]
    WHERE [a].[StudentEmail] = @email OR [a].[JambRegNumber] = @jambRegNumber
    ORDER BY [a].[CreatedAt] DESC
) AS [s]
LEFT JOIN (
