SELECT [l1].[Id], [c0].[Code], [c0].[Title], [l1].[SessionDate], [l1].[StartTime], [l1].[EndTime], [s].[Name], [c].[Id], [c0].[Id], [s].[Id], [s2].[c], [s2].[LectureSessionId], [s2].[LecturerId], [s2].[Id], [l1].[IsManuallyCreated], [l1].[IsCompleted], (
