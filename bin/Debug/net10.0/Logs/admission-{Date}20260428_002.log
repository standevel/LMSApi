    ELSE N'Unknown'
END AS [ProgramName], [a0].[Name] AS [SessionName], [a].[OfferAcceptedAt]
FROM [AdmissionApplications] AS [a]
LEFT JOIN [Programs] AS [p] ON [a].[AcademicProgramId] = [p].[Id]
INNER JOIN [AcademicSessions] AS [a0] ON [a].[AcademicSessionId] = [a0].[Id]
WHERE [a].[Status] = N'OfferAccepted' AND ([a].[EntraObjectId] IS NULL OR [a].[EntraObjectId] LIKE N'' OR [a].[StudentId] IS NULL)
ORDER BY [a].[OfferAcceptedAt]
