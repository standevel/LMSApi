    SELECT [l].[Id], [l].[CourseOfferingId], [l].[EndTime], [l].[IsCompleted], [l].[IsManuallyCreated], [l].[SessionDate], [l].[StartTime], [l].[VenueId]
    FROM [LectureSessions] AS [l]
    ORDER BY [l].[SessionDate], [l].[StartTime]
    OFFSET @p ROWS FETCH NEXT @p1 ROWS ONLY
) AS [l0]
INNER JOIN [CourseOfferings] AS [c] ON [l0].[CourseOfferingId] = [c].[Id]
INNER JOIN [Courses] AS [c0] ON [c].[CourseId] = [c0].[Id]
LEFT JOIN [Subjects] AS [s] ON [l0].[VenueId] = [s].[Id]
LEFT JOIN (
    SELECT COALESCE([u].[DisplayName], [u].[Email], N'Unknown') AS [c], [l1].[LectureSessionId], [l1].[LecturerId], [u].[Id]
    FROM [LectureSessionLecturers] AS [l1]
    INNER JOIN [Users] AS [u] ON [l1].[LecturerId] = [u].[Id]
) AS [s2] ON [l0].[Id] = [s2].[LectureSessionId]
ORDER BY [l0].[SessionDate], [l0].[StartTime], [l0].[Id], [c].[Id], [c0].[Id], [s].[Id], [s2].[LectureSessionId], [s2].[LecturerId]
